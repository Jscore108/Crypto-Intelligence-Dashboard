# Crypto Intelligence Dashboard — Alert Configuration
# Copy this to .env and fill in your values
# NEVER commit the .env file to git

# --- SendGrid (recommended) ---
SENDGRID_API_KEY=

# --- SMTP (Gmail/ProtonMail alternative) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Alert destination ---
ALERT_EMAIL=
